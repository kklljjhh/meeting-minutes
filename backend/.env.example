# 阿里云百炼 Fun-ASR 录音转写配置
# 到 https://dashscope.console.aliyun.com 获取
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 讯飞星火Spark API配置
# 到 https://console.xfyun.cn/services/cbm 获取
XF_SPARK_URL=https://spark-api-open.xf-yun.com/v1/chat/completions
XF_SPARK_PASSWORD=your_api_key:your_api_secret

# 服务器配置
PORT=3000
